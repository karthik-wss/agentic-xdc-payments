# XDC Network Agent Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Wallet ──────────────────────────────────────────────
# Choose how the agent signs. Hot keys (options 1/2) are for DEV/CI only — for
# real value, prefer a hardware wallet (option 3). See SECURITY.md.

# Option 1: Private key (hex, with or without 0x prefix)
PRIVATE_KEY=0x_your_private_key_here

# Option 2: Mnemonic phrase (12 or 24 words)
# MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Option 3: Ledger hardware wallet (keys never leave the device; you confirm on-device).
# Set WALLET_TYPE=ledger and install the optional deps:
#   npm install @ledgerhq/hw-app-eth @ledgerhq/hw-transport-node-hid
# WALLET_TYPE=ledger
# LEDGER_DERIVATION_PATH=44'/60'/0'/0/0

# ── LLM Provider ─────────────────────────────────────────
# The agent auto-detects its provider: if XAI_API_KEY is set, Grok is used;
# otherwise it falls back to Anthropic. Set LLM_PROVIDER to force one when both
# keys are present.
# LLM_PROVIDER=anthropic        # or "grok"

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-your_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-5

# xAI Grok (OpenAI-compatible; https://api.x.ai/v1)
# XAI_API_KEY=xai-your_api_key_here
# GROK_MODEL=grok-4.3

# ── XDC Network ─────────────────────────────────────────
# Mainnet (default). For Apothem testnet, see the testnet block further down.
XDC_RPC_URL=https://rpc.xinfin.network
XDC_CHAIN_ID=50

# ── Tokens ───────────────────────────────────────────────
# Built-in tokens: XDC (native) and USDC (below). Native XDC needs no address.
# XDC Mainnet USDC (update if using a different USDC variant)
USDC_CONTRACT_ADDRESS=0xfa2958cb79b0491cc627c1557f441ef849ca8eb1

# Extra ERC-20 tokens the agent should support, comma-separated as SYMBOL:0xADDRESS
# Adding a token here is a settings change — no code edits needed.
# TOKENS=USDT:0x0000000000000000000000000000000000000000,WXDC:0x0000000000000000000000000000000000000000

# ── DEX / Swaps (XSwap, UniswapV2-style) ─────────────────
# Required for "Swap X to Y". Addresses below are from the official XSwap docs
# (docs.xspswap.finance/xswap-protocol/contracts) — re-verify before mainnet use.
# XSwap V2 Router + WXDC on XDC MAINNET:
XSWAP_ROUTER_ADDRESS=0xf9c5E4f6E627201aB2d6FB6391239738Cf4bDcf9
WXDC_ADDRESS=0x951857744785E80e2De051c32EE7b25f9c458C42
# Max slippage tolerated on a swap, in percent (default 1)
SWAP_SLIPPAGE_PERCENT=1

# ── Gas ──────────────────────────────────────────────────
# XDC uses legacy type-0 txs at a stable ~12.5 gwei. Gas LIMIT is estimated live
# (+20% buffer) with the per-op constants as a floor; only the PRICE is set here.
# XDC_GAS_PRICE_GWEI=12.5

# ── Apothem testnet (uncomment this whole block to test without real funds) ──
# XDC_RPC_URL=https://erpc.apothem.network
# XDC_CHAIN_ID=51
# XSwap V2 Router + WXDC on APOTHEM TESTNET (from official XSwap docs):
# XSWAP_ROUTER_ADDRESS=0x3F11A24EB45d3c3737365b97A996949dA6c2EdDf
# WXDC_ADDRESS=0x2a5c77b016Df1b3b0AE4E79a68F8adF64Ee741ba
# No canonical USDC on Apothem — use XSwap's test token (XTT, has WXDC liquidity)
# to exercise swaps, e.g. "Swap 1 XDC to XTT":
# TOKENS=XTT:0x17476dc3eda45aD916cEAdDeA325B240A7FB259D
# (Apothem has no preset USDC; set USDC_CONTRACT_ADDRESS only if you deploy/find one.)
# Faucet: https://faucet.apothem.network

# ── Agent Behaviour ──────────────────────────────────────
# Require confirmation before every send/swap (true/false)
REQUIRE_CONFIRMATION=true

# Maximum amount per single transfer/swap (safety limit; raw number, not USD-normalized)
MAX_SEND_AMOUNT=1000
